<html xmlns="http://www.w3.org/1999/xhtml"
      lang="en-US"
      metal:use-macro="context/prefs_main_template/macros/master"
      xml:lang="en-US"
>

  <tal:block metal:fill-slot="top_slot">
    <tal:block tal:define="
                 dummy python:request.set('disable_border',1);
               " />
  </tal:block>

  <body>
    <div metal:fill-slot="prefs_configlet_main"
         tal:define="
           errors python:request.get('errors', {});
           search python:request.get('search', '');
           portal_type python:request.get('portal_type', '');
           field python:request.get('field', '');
           fkey python:request.get('fkey', '');
           match python:request.get('match', '');
           values view/get_values;
           results view/results;
         "
    >

      <h1 i18n:translate="heading_schema_field_manager">Content Field Manager</h1>

      <div class="documentDescription">
        The portal_type field manager allows you to delete and merge fields in your portal. As a reminder, you can
        use the
        <a href="${context/absolute_url}/manage_UndoForm"
           target="_blank"
        >undo form</a>
         to
        rollback
        changes.
      </div>

      <tal:schema_fields tal:define="
                           portal_types view/get_types;
                         ">
        <form action="${context/absolute_url}/mass-edit"
              method="get"
        >
          <fieldset>
            <legend>
                    Choose Type
            </legend>

            <div class="field">
              <label class="form-label"
                     for="typefield"
                     i18n:translate="label_typefield"
              >
                        Type
              </label>

              <select class="form-control"
                      id="typefield"
                      name="portal_type"
                      onchange="javascript:this.form.submit()"
              >
                <option selected="${python:fld['id']==portal_type}"
                        value="${fld/id}"
                        tal:repeat="fld portal_types"
                        i18n:domain="plone"
                        i18n:translate=""
                >
                                ${fld/title}
                </option>
              </select>

              <span tal:define="
                      type_matches python:view.type_matches(portal_type);
                    "
                    tal:condition="portal_type"
              >
                        Objects using this field: ${type_matches}
              </span>
            </div>

            <div class="formControls">
              <input class="btn btn-primary"
                     type="submit"
                     value="Select Type"
                     i18n:attributes="value"
              />
            </div>

          </fieldset>
        </form>
      </tal:schema_fields>

      <tal:schema_selected condition="portal_type">
        <form action="${context/absolute_url}/mass-edit"
              method="get"
              tal:define="
                fields view/get_fields;
              "
        >

          <input name="portal_type"
                 type="hidden"
                 value="${portal_type}"
          />
          <fieldset id="fieldset-schema">
            <legend>
                    Choose Field
            </legend>

            <div class="field">
              <label for="fieldfield"
                     i18n:translate="label_field_field"
              >
                        Field
              </label>

              <select id="fieldfield"
                      name="field"
                      onchange="javascript:this.form.submit()"
              >
                <option selected="${python:fld['id']==field}"
                        value="${fld/id}"
                        tal:repeat="fld fields"
                        i18n:domain="plone"
                        i18n:translate=""
                >
                                ${fld/title}
                </option>
              </select>
            </div>

            <div class="formControls">
              <input class="btn btn-primary"
                     type="submit"
                     value="Select Field"
                     i18n:attributes="value"
              />
            </div>

          </fieldset>
        </form>
      </tal:schema_selected>

      <tal:schema_data_grid condition="view/is_dg">
        <form action="${context/absolute_url}/mass-edit"
              method="get"
              tal:define="
                dgkeys view/get_dgkeys;
              "
        >

          <input name="portal_type"
                 type="hidden"
                 value="${portal_type}"
          />
          <input name="field"
                 type="hidden"
                 value="${field}"
          />
          <fieldset id="fieldset-field">
            <legend>
                    Choose DataGrid Key
            </legend>

            <div class="field">
              <label for="fkeyfield"
                     i18n:translate="labelfkey_field"
              >
                        Key
              </label>

              <select id="dgkeyfield"
                      name="fkey"
                      onchange="javascript:this.form.submit()"
              >
                <option selected="${python:dgkey['id']==fkey}"
                        value="${dgkey/id}"
                        tal:repeat="dgkey dgkeys"
                        i18n:domain="plone"
                        i18n:translate=""
                >
                                ${dgkey/title}
                </option>
              </select>
            </div>

            <div class="formControls">
              <input class="btn btn-primary"
                     type="submit"
                     value="Select DataGrid Key"
                     i18n:attributes="value"
              />
            </div>

          </fieldset>
        </form>
      </tal:schema_data_grid>

      <tal:unsupported condition="view/unsupported">
        Unsupported value type for this field: ${view/unsupported}. Unfortunately this data
        type is not convertable through this form.
      </tal:unsupported>

      <tal:values condition="values">
        <form action="${context/absolute_url}/mass-edit"
              method="get"
              tal:attributes="
                action string:;
              "
        >

          <input name="portal_type"
                 type="hidden"
                 value="${portal_type}"
          />
          <input name="field"
                 type="hidden"
                 value="${field}"
          />
          <input name="fkey"
                 type="hidden"
                 value="${fkey}"
          />
          <fieldset id="fieldset-fkey">
            <legend>
                    Choose Current Value
            </legend>

            <div class="field">
              <label for="fkeyfield"
                     i18n:translate="labelfkey_field"
              >
                        Matching Value
              </label>

              <select id="valuefield"
                      name="match"
                      onchange="javascript:this.form.submit()"
              >
                <option selected="${python:value==match}"
                        value="${value}"
                        tal:repeat="value values"
                        i18n:domain="plone"
                        i18n:translate=""
                >
                                ${value}
                </option>
              </select>
            </div>

            <div class="formControls">
              <input class="btn btn-primary"
                     name="form.button.Merge"
                     title="Select value"
                     type="submit"
                     value="Select value"
                     i18n:attributes="value; title"
              />
            </div>
          </fieldset>
        </form>
      </tal:values>

      <tal:no_results tal:condition="python:field and not results">
        No values found for this field.
      </tal:no_results>

      <tal:replace_or_delete tal:condition="results">
        <form action="mass-edit"
              method="post"
              tal:attributes="
                action string:${context/absolute_url}/mass-edit;
              "
        >
          <input name="portal_type"
                 type="hidden"
                 value="${portal_type}"
          />
          <input name="field"
                 type="hidden"
                 value="${field}"
          />
          <input name="fkey"
                 type="hidden"
                 value="${fkey}"
          />
          <input name="match"
                 type="hidden"
                 value="${match}"
          />

          <fieldset id="fieldset-match">
            <legend>
                    Current Matches
            </legend>

            <div class="portalMessage statusmessage statusmessage-warn alert alert-warning">
              <tal:icon tal:replace="structure python:icons.tag('plone-statusmessage-info', tag_alt='status', tag_class='statusmessage-icon mb-1 me-2')" />
              <div>Warning</div>
                    Proceed with caution! All content listed here will be affected by modification or deletion.
            </div>

            <ul>
              <tal:result repeat="result results">
                <li>
                  <a href="${result/getURL}"
                     target="_blank"
                  >
                                    ${result/Title}
                  </a>
                </li>
              </tal:result>
            </ul>

            <div class="field">
              <div class="error"
                   tal:define="
                     err errors/changeto|nothing;
                   "
                   tal:condition="err"
                   i18n:translate=""
              >
                            ${err}
              </div>
              <label for="replacement"
                     i18n:translate=""
              >Value to apply</label>
              <!--<input id="replacement" type="text" name="replacement"/>-->
              <input name="replacement_marker"
                     type="hidden"
                     value="1"
              />
              <span tal:replace="structure python:view.replacement_widget.render()"></span>
            </div>

            <div class="formControls">
              <input class="btn btn-warning"
                     name="form.button.Merge"
                     title="Replace all values"
                     type="submit"
                     value="Replace with this value"
                     i18n:attributes="value; title"
              />

              <input class="btn btn-warning"
                     id="input_delete_keyword"
                     name="form.button.Delete"
                     title="Remove values"
                     type="submit"
                     value="Remove this value"
                     i18n:attributes="value; title"
              />
            </div>
          </fieldset>
        </form>
      </tal:replace_or_delete>
    </div>
  </body>
</html>
